model User {
  id    String  @id @default(uuid()) 
  email String  @unique @db.VarChar(254)
  loginId String @unique @db.VarChar(13) @map("login_id")
  password String
  name  String @db.VarChar(50)
  nickname String @unique @db.VarChar(32)
  image String? 
  gender Gender? 
  birthDay DateTime? @db.Date @map("birth_day")
  phoneNumber String? @unique @db.VarChar(15) @map("phone_number")
  isPublic State @default(TRUE) @map("is_public")
  verify State @default(FALSE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt State @default(FALSE) @map("deleted_at")

  // one to many
  roles Role[]
  posts Post[]
  comments Comment[]
  likes Like[]

  @@map(name: "users")
}

// 성별 enum
enum Gender { 
  MALE 
  FEMALE 
}