datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"

  engineType = "client"
  runtime = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
} 

/** 
* 공통 enum 
**/

enum State { 
  TRUE 
  FALSE 
}

enum Category {
  // 자유
  FREE
  // 스포츠 
  SPORTS
  // 게임
  GAME
}

// 게시글, 댓글, 대댓글 분기 처리
enum Type {
  // 게시글
  POST
  // 댓글
  COMMENT
  // 대댓글
  REPLY
}